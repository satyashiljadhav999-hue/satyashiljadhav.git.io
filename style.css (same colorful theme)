body {
    font-family: Arial;
    margin: 0;
    background: linear-gradient(to right, #ff6a00, #ee0979);
    color: white;
}

header {
    text-align: center;
    padding: 20px;
    background: #ff4b2b;
}

nav {
    text-align: center;
    background: #222;
    padding: 10px;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    color: yellow;
}

section {
    padding: 30px;
}

ul {
    background: rgba(255,255,255,0.2);
    padding: 15px;
    border-radius: 10px;
}

footer {
    text-align: center;
    padding: 10px;
    background: #111;
}
